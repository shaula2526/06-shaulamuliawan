<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>CRUD User - Modular</title>

  <style>
    body {
      font-family: Arial;
      background: #f4f4f4;
      text-align: center;
    }

    h1 {
      margin-top: 20px;
    }

    input {
      padding: 10px;
      margin: 5px;
      width: 250px;
    }

    button {
      padding: 10px;
      background: green;
      color: white;
      border: none;
      cursor: pointer;
    }

    .card {
      background: white;
      padding: 20px;
      margin: 20px auto;
      width: 300px;
      border-radius: 10px;
      box-shadow: 0 3px 8px rgba(0,0,0,0.2);
    }

    .list-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }

    .user-card {
      background: white;
      width: 200px;
      margin: 10px;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }

    .user-card button {
      margin-top: 10px;
      background: red;
    }
  </style>

</head>
<body>

<h1>CRUD Data User</h1>

<input type="text" id="search" placeholder="Cari nama..." />

<div class="card">
  <h2>Tambah User</h2>
  <input type="text" id="nama" placeholder="Nama">
  <input type="number" id="umur" placeholder="Umur">
  <button onclick="addUser()">Tambah</button>
</div>

<h2>List User</h2>
<div id="userList" class="list-container"></div>

<script>
// ===== DATA =====
let users = [];

// ===== UTILS =====
const getInputValue = (id) => document.getElementById(id).value;

const clearInputs = () => {
  document.getElementById("nama").value = "";
  document.getElementById("umur").value = "";
};

// ===== COMPONENT =====
const createUserCard = (user, index) => {
  return `
    <div class="user-card">
      <h3>${user.nama}</h3>
      <p>Umur: ${user.umur}</p>
      <button onclick="deleteUser(${index})">Hapus</button>
    </div>
  `;
};

// ===== RENDER =====
const renderUsers = (data = users) => {
  const container = document.getElementById("userList");

  if (data.length === 0) {
    container.innerHTML = "<p>Tidak ada data</p>";
    return;
  }

  container.innerHTML = data
    .map((user, index) => createUserCard(user, index))
    .join("");
};

// ===== CRUD =====
const addUser = () => {
  const nama = getInputValue("nama");
  const umur = getInputValue("umur");

  if (!nama || !umur) return alert("Isi semua field!");

  users.push({ nama, umur });

  clearInputs();
  renderUsers();
};

const deleteUser = (index) => {
  users.splice(index, 1);
  renderUsers();
};

// ===== SEARCH =====
document.getElementById("search").addEventListener("input", (e) => {
  const keyword = e.target.value.toLowerCase();

  const filtered = users.filter(user =>
    user.nama.toLowerCase().includes(keyword)
  );

  renderUsers(filtered);
});

// ===== INIT =====
renderUsers();

</script>

</body>
</html>
